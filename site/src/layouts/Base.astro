---
import '@fontsource-variable/cormorant';
import '@fontsource-variable/cormorant/wght-italic.css';
import '@fontsource-variable/manrope';
import '../styles/tokens.css';

interface Props {
	title: string;
	description?: string;
	/** Именные страницы прячем от поисковиков */
	noindex?: boolean;
}

const { title, description = 'Приглашение на свадьбу Ильи и Елены — 6 августа 2026', noindex = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		{/* Помечаем документ как «с JS» до отрисовки — скролл-анимации прячут контент
		    только когда JS есть; без него всё видно сразу. */}
		<script is:inline>document.documentElement.classList.add('js');</script>
		<meta name="description" content={description} />
		{noindex && <meta name="robots" content="noindex" />}
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
		<script>
			// Плавное появление секций при скролле. Уважаем prefers-reduced-motion
			// и деградируем без сюрпризов: без JS класса .js нет — контент виден.
			const reveals = document.querySelectorAll<HTMLElement>('[data-reveal]');
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (reduce || !('IntersectionObserver' in window)) {
				reveals.forEach((el) => el.classList.add('is-revealed'));
			} else {
				const io = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-revealed');
								io.unobserve(entry.target);
							}
						});
					},
					{ rootMargin: '0px 0px -12% 0px', threshold: 0.12 }
				);
				reveals.forEach((el) => io.observe(el));
			}
		</script>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		background: var(--color-bg);
		color: var(--color-text);
		font-family: var(--font-body);
		font-size: var(--text-base);
		line-height: 1.65;
		-webkit-font-smoothing: antialiased;
	}

	h1,
	h2,
	h3 {
		font-family: var(--font-display);
		font-weight: 500;
		line-height: 1.15;
	}

	a {
		color: var(--color-accent-ink);
	}

	/* Надзаголовок секции — Manrope 600, разрядка, капс */
	.eyebrow {
		margin: 0;
		color: var(--color-accent-ink);
		font-size: var(--text-caption);
		font-weight: 600;
		letter-spacing: 0.22em;
		text-transform: uppercase;
	}

	/* Кнопки — единый стиль из дизайн-системы */
	.btn {
		display: inline-block;
		padding: 0.8em 2.2em;
		border-radius: var(--radius);
		border: 1px solid transparent;
		font-family: var(--font-body);
		font-size: var(--text-base);
		font-weight: 600;
		letter-spacing: 0.06em;
		text-decoration: none;
		cursor: pointer;
		transition: background var(--transition), border-color var(--transition),
			color var(--transition), transform var(--transition);
	}
	.btn-primary {
		background: var(--color-accent-ink);
		color: var(--color-bg);
	}
	.btn-primary:hover {
		background: #7a5744;
	}
	.btn-primary:active {
		transform: translateY(1px);
	}
	.btn-primary[disabled] {
		background: var(--color-line);
		color: var(--color-text-muted);
		cursor: not-allowed;
	}
	.btn-ghost {
		background: transparent;
		border-color: var(--color-accent-ink);
		color: var(--color-accent-ink);
	}
	.btn-ghost:hover {
		background: rgba(140, 103, 83, 0.08);
	}
	.btn:focus-visible {
		outline: 2px solid var(--color-accent-ink);
		outline-offset: 2px;
	}

	/* Скролл-анимация появления. Прячем контент только при активном JS (html.js),
	   чтобы без скриптов страница осталась читаемой. */
	html.js [data-reveal] {
		opacity: 0;
		transform: translateY(24px);
		transition: opacity 0.75s ease, transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
		will-change: opacity, transform;
	}
	html.js [data-reveal].is-revealed {
		opacity: 1;
		transform: none;
	}
	@media (prefers-reduced-motion: reduce) {
		html.js [data-reveal] {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}
</style>
