---
import Section from './Section.astro';
import { wedding } from '../data/wedding';
const { host } = wedding;

// Инициал для монограммы: первая буква имени, если оно ещё не заглушка.
const initial = /^[A-Za-zА-Яа-яЁё]/.test(host.name) ? host.name[0].toUpperCase() : '★';
---

<Section id="host" class="host-section" eyebrow={host.role} title="Кто рядом с нами">
	<div class="host">
		<a class="portrait" href={host.url} target="_blank" rel="noopener noreferrer" aria-label={`Профиль: ${host.name}`}>
			<span class="mono">{initial}</span>
		</a>
		<a class="name" href={host.url} target="_blank" rel="noopener noreferrer">{host.name}</a>
		<p class="note">{host.note}</p>

		<div class="surprise">
			<p>{host.surprise}</p>
			<a class="btn btn-ghost" href={host.surpriseUrl} target="_blank" rel="noopener noreferrer">
				Написать Наталье
			</a>
		</div>
	</div>
</Section>

<style>
	/* Собственный мягкий фон айвори → беж: секция читается как отдельный акцент
	   и заодно переливается в бежевую галерею ниже. */
	:global(.host-section) {
		background: linear-gradient(to bottom, var(--color-bg) 0%, var(--color-bg-alt) 100%);
	}
	.host {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: var(--space-3);
	}
	.portrait {
		position: relative;
		width: 7rem;
		height: 7rem;
		border-radius: 50%;
		display: grid;
		place-items: center;
		background: var(--color-surface);
		border: 1px solid var(--color-line);
		box-shadow: 0 10px 30px -18px rgba(61, 56, 51, 0.5);
		text-decoration: none;
		transition: transform var(--transition), box-shadow var(--transition);
	}
	.portrait:hover {
		transform: translateY(-2px);
		box-shadow: 0 16px 34px -18px rgba(61, 56, 51, 0.6);
	}
	.portrait::after {
		content: '';
		position: absolute;
		width: 8.2rem;
		height: 8.2rem;
		border-radius: 50%;
		border: 1px solid var(--color-accent);
		opacity: 0.4;
	}
	.mono {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--text-h1);
		color: var(--color-accent);
	}
	.name {
		margin: var(--space-2) 0 0;
		font-family: var(--font-display);
		font-size: var(--text-h2);
		color: var(--color-accent-ink);
		text-decoration: none;
	}
	.name:hover {
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}
	.note {
		margin: 0;
		max-width: 30rem;
		color: var(--color-text-muted);
	}
	.surprise {
		margin-top: var(--space-3);
		padding: var(--space-4);
		max-width: 32rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-3);
		background: var(--color-surface);
		border: 1px solid var(--color-line);
		border-radius: var(--radius);
	}
	.surprise p {
		margin: 0;
		color: var(--color-text-muted);
		font-size: var(--text-base);
	}
</style>
