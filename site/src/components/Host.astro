---
import Section from './Section.astro';
import { wedding } from '../data/wedding';
const { host } = wedding;

// Инициал для монограммы: первая буква имени, если оно ещё не заглушка.
const initial = /^[A-Za-zА-Яа-яЁё]/.test(host.name) ? host.name[0].toUpperCase() : '★';
---

<Section id="host" class="host-section" eyebrow={host.role} title="Кто рядом с нами">
	<div class="host">
		<div class="portrait" aria-hidden="true">
			<span class="mono">{initial}</span>
		</div>
		<p class="name">{host.name}</p>
		<p class="note">{host.note}</p>
	</div>
</Section>

<style>
	/* Собственный мягкий фон айвори → беж: секция читается как отдельный акцент
	   и заодно переливается в бежевую галерею ниже. */
	:global(.host-section) {
		background: linear-gradient(to bottom, var(--color-bg) 0%, var(--color-bg-alt) 100%);
	}
	.host {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: var(--space-3);
	}
	.portrait {
		position: relative;
		width: 7rem;
		height: 7rem;
		border-radius: 50%;
		display: grid;
		place-items: center;
		background: var(--color-surface);
		border: 1px solid var(--color-line);
		box-shadow: 0 10px 30px -18px rgba(61, 56, 51, 0.5);
	}
	.portrait::after {
		content: '';
		position: absolute;
		width: 8.2rem;
		height: 8.2rem;
		border-radius: 50%;
		border: 1px solid var(--color-accent);
		opacity: 0.4;
	}
	.mono {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--text-h1);
		color: var(--color-accent);
	}
	.name {
		margin: var(--space-2) 0 0;
		font-family: var(--font-display);
		font-size: var(--text-h2);
		color: var(--color-accent-ink);
	}
	.note {
		margin: 0;
		max-width: 30rem;
		color: var(--color-text-muted);
	}
</style>
