---
import Section from './Section.astro';
import { wedding } from '../data/wedding';

interface Props {
	/** slug именного гостя — уходит в скрытое поле контракта RSVP */
	guest?: string;
	/** Верхняя граница числа гостей в ответе */
	maxGuests?: number;
}
const { guest, maxGuests = 5 } = Astro.props;
const counts = Array.from({ length: Math.max(1, maxGuests) }, (_, i) => i + 1);
---

<Section id="rsvp" eyebrow="Будете с нами?" title="Подтвердите присутствие">
	<form class="rsvp" novalidate data-endpoint={wedding.rsvpEndpoint}>
		{guest && <input type="hidden" name="guest" value={guest} />}
		<div class="field">
			<label for="rsvp-name">Ваше имя</label>
			<input class="input" id="rsvp-name" name="name" type="text" placeholder="Имя и фамилия" autocomplete="name" required />
		</div>

		<div class="field">
			<label>Придёте?</label>
			<div class="choices">
				<label class="choice"><input type="radio" name="attending" value="yes" checked /> С радостью приду</label>
				<label class="choice"><input type="radio" name="attending" value="no" /> К сожалению, не смогу</label>
			</div>
		</div>

		<div class="field" data-if-attending>
			<label for="rsvp-count">Сколько вас будет</label>
			<select class="input" id="rsvp-count" name="guestsCount">
				{counts.map((n) => <option value={n}>{n === 1 ? '1 — только я' : n}</option>)}
			</select>
		</div>

		<div class="field" data-if-attending>
			<label>Напитки и аллергии</label>
			{maxGuests > 1 && <p class="hint">Заполните на каждого — у всех по-разному</p>}
			<div class="people">
				{counts.map((n) => (
					<fieldset class="person" data-person={n - 1} hidden={n > 1}>
						{maxGuests > 1 && <legend>{n === 1 ? 'Вы' : `Гость ${n}`}</legend>}
						<div class="choices">
							<label class="choice"><input type="checkbox" name={`alcohol-${n - 1}`} value="red" /> Красное вино</label>
							<label class="choice"><input type="checkbox" name={`alcohol-${n - 1}`} value="white" /> Белое вино</label>
							<label class="choice"><input type="checkbox" name={`alcohol-${n - 1}`} value="champagne" /> Шампанское</label>
							<label class="choice"><input type="checkbox" name={`alcohol-${n - 1}`} value="strong" /> Крепкие напитки</label>
							<label class="choice"><input type="checkbox" name={`alcohol-${n - 1}`} value="none" /> Не пью</label>
						</div>
						<input class="input person-diet" name={`diet-${n - 1}`} type="text" placeholder="Аллергии — например, орехи" aria-label="Аллергии" />
					</fieldset>
				))}
			</div>
		</div>

		{/* honeypot: скрытое поле для отсева ботов */}
		<input class="honeypot" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />

		<button class="btn btn-primary" type="submit">Отправить</button>
		<p class="status" role="status" aria-live="polite" hidden></p>
	</form>
</Section>

<script>
	function initRsvp(form: HTMLFormElement): void {
		const endpoint = form.dataset.endpoint;
		const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
		const status = form.querySelector<HTMLParagraphElement>('.status');
		const attendingInputs = form.querySelectorAll<HTMLInputElement>('input[name="attending"]');
		const conditionalFields = form.querySelectorAll<HTMLElement>('[data-if-attending]');
		const countSelect = form.querySelector<HTMLSelectElement>('select[name="guestsCount"]');
		const personFieldsets = form.querySelectorAll<HTMLFieldSetElement>('fieldset.person');

		function syncAttendance(): void {
			const attending = form.querySelector<HTMLInputElement>('input[name="attending"]:checked')?.value === 'yes';
			conditionalFields.forEach((field) => {
				field.hidden = !attending;
			});
		}
		attendingInputs.forEach((input) => input.addEventListener('change', syncAttendance));
		syncAttendance();

		// Показываем по одной группе напитков на каждого заявленного гостя.
		function syncPeople(): void {
			const count = Number(countSelect?.value ?? 1);
			personFieldsets.forEach((fs, i) => {
				fs.hidden = i >= count;
			});
		}
		countSelect?.addEventListener('change', syncPeople);
		syncPeople();

		// «Не пью» взаимоисключает остальное — в пределах своей группы.
		personFieldsets.forEach((fs) => {
			const inputs = fs.querySelectorAll<HTMLInputElement>('input[type="checkbox"]');
			const none = fs.querySelector<HTMLInputElement>('input[value="none"]');
			inputs.forEach((input) => {
				input.addEventListener('change', () => {
					if (input === none && input.checked) {
						inputs.forEach((other) => {
							if (other !== none) other.checked = false;
						});
					} else if (input !== none && input.checked && none) {
						none.checked = false;
					}
				});
			});
		});

		function showStatus(text: string, tone: 'success' | 'error'): void {
			if (!status) return;
			status.textContent = text;
			status.className = `status status-${tone}`;
			status.hidden = false;
		}

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			if (!endpoint || !submitBtn) return;

			const data = new FormData(form);
			const attending = data.get('attending') === 'yes';
			const guestsCount = attending ? Number(data.get('guestsCount') ?? 1) : 1;
			const people = attending
				? Array.from({ length: guestsCount }, (_, i) => ({
						alcohol: data.getAll(`alcohol-${i}`) as string[],
						dietary: String(data.get(`diet-${i}`) ?? '').trim(),
					}))
				: [];
			const payload = {
				guest: (data.get('guest') as string | null) ?? null,
				name: String(data.get('name') ?? '').trim(),
				attending,
				guestsCount,
				people,
				website: String(data.get('website') ?? ''),
			};

			submitBtn.disabled = true;
			submitBtn.textContent = 'Отправляем…';
			if (status) status.hidden = true;

			try {
				const res = await fetch(`${endpoint}/rsvp`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(payload),
				});
				if (!res.ok) throw new Error('request_failed');

				form.querySelectorAll('input, select, textarea, button').forEach((el) => {
					(el as HTMLInputElement | HTMLButtonElement).disabled = true;
				});
				submitBtn.textContent = 'Ответ отправлен';
				showStatus(attending ? 'Спасибо, ждём вас!' : 'Спасибо, что предупредили — будем скучать!', 'success');
			} catch {
				submitBtn.disabled = false;
				submitBtn.textContent = 'Отправить';
				showStatus('Не получилось отправить ответ. Напишите нам в Telegram @elgrudina394 — передадим лично.', 'error');
			}
		});
	}

	document.querySelectorAll<HTMLFormElement>('form.rsvp').forEach(initRsvp);
</script>

<style>
	.rsvp {
		max-width: 26rem;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}
	.field {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.field > label {
		font-size: var(--text-caption);
		font-weight: 600;
		letter-spacing: 0.06em;
	}
	.input,
	.textarea {
		width: 100%;
		padding: 0.75em 1em;
		border: 1px solid var(--color-line);
		border-radius: var(--radius);
		background: var(--color-surface);
		color: var(--color-text);
		font-family: var(--font-body);
		font-size: var(--text-base);
		transition: border-color var(--transition), box-shadow var(--transition);
	}
	.input::placeholder,
	.textarea::placeholder {
		color: var(--color-text-muted);
		opacity: 0.7;
	}
	.input:focus,
	.textarea:focus {
		outline: none;
		border-color: var(--color-accent);
		box-shadow: 0 0 0 3px rgba(176, 141, 122, 0.18);
	}
	.textarea {
		min-height: 6em;
		resize: vertical;
	}
	.hint {
		margin: -0.35rem 0 0;
		font-size: var(--text-caption);
		color: var(--color-text-muted);
	}
	.people {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}
	.person {
		margin: 0;
		padding: 0;
		border: 0;
		min-inline-size: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.person:not([hidden]) + .person:not([hidden]) {
		padding-top: var(--space-3);
		border-top: 1px solid var(--color-line);
	}
	.person legend {
		padding: 0;
		margin-bottom: var(--space-2);
		font-size: var(--text-caption);
		font-weight: 600;
		letter-spacing: 0.06em;
		color: var(--color-accent-ink);
	}
	.choices {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.choice {
		display: flex;
		align-items: center;
		gap: 0.65em;
		font-size: var(--text-base);
		cursor: pointer;
	}
	.choice input {
		appearance: none;
		width: 1.25em;
		height: 1.25em;
		margin: 0;
		border: 1.5px solid var(--color-accent);
		background: var(--color-surface);
		cursor: pointer;
		display: grid;
		place-content: center;
		transition: background var(--transition);
	}
	.choice input[type='radio'] {
		border-radius: 50%;
	}
	.choice input[type='checkbox'] {
		border-radius: 0.2em;
	}
	.choice input::before {
		content: '';
		width: 0.55em;
		height: 0.55em;
		transform: scale(0);
		transition: transform var(--transition);
		background: var(--color-accent-ink);
	}
	.choice input[type='radio']::before {
		border-radius: 50%;
	}
	.choice input:checked {
		border-color: var(--color-accent-ink);
	}
	.choice input:checked::before {
		transform: scale(1);
	}
	.choice input:focus-visible {
		outline: 2px solid var(--color-accent-ink);
		outline-offset: 2px;
	}
	.btn-primary {
		margin-top: var(--space-2);
	}
	.status {
		margin: 0;
		font-size: var(--text-base);
		text-align: center;
	}
	.status-success {
		color: var(--color-accent-ink);
	}
	.status-error {
		color: #a3453a;
	}
	/* honeypot прячем и от глаз, и от скринридеров */
	.honeypot {
		position: absolute;
		left: -9999px;
		width: 1px;
		height: 1px;
		opacity: 0;
		pointer-events: none;
	}
</style>
