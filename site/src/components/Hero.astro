---
import { Image } from 'astro:assets';
import heroSrc from '../assets/hero.jpg';
import { wedding, type Personalization } from '../data/wedding';

interface Props {
	/** На именной странице — персональное обращение над именами пары */
	personal?: Personalization;
}
const { personal } = Astro.props;
const { couple, dateLabel, venue } = wedding;
---

<header class="hero">
	<div class="hero-inner">
		<figure class="photo">
			<Image
				src={heroSrc}
				alt={`${couple.groom} и ${couple.bride}`}
				widths={[414, 640, 828]}
				sizes="(min-width: 40rem) 24rem, 82vw"
				loading="eager"
				fetchpriority="high"
			/>
		</figure>
		{personal && <p class="hello">{personal.heroLine}</p>}
		<p class="eyebrow">Приглашение на свадьбу</p>
		<h1 class="names">
			{couple.groom}
			<span class="amp">&amp;</span>
			{couple.bride}
		</h1>
		<p class="date-line">{dateLabel}</p>
		<p class="place">{venue.name} · {venue.city}</p>
	</div>
	<a class="scroll-hint" href="#invitation" aria-label="Пролистать вниз">↓</a>
</header>

<style>
	.hero {
		position: relative;
		min-height: 100svh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: var(--space-5) var(--space-4);
		text-align: center;
	}
	.hero-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-3);
	}
	/* Фото целиком, без кропа — рамка подстраивается под пропорции снимка */
	.photo {
		position: relative;
		margin: 0 0 var(--space-2);
		width: min(82vw, 24rem);
		border-radius: var(--radius);
		overflow: hidden;
		box-shadow: 0 26px 55px -26px rgba(61, 56, 51, 0.6);
	}
	.photo :global(img) {
		display: block;
		width: 100%;
		height: auto;
	}
	/* Тонкая светлая линия внутри — классическая «паспарту»-рамка */
	.photo::after {
		content: '';
		position: absolute;
		inset: 0.55rem;
		border: 1px solid rgba(255, 253, 248, 0.65);
		border-radius: calc(var(--radius) - 1px);
		pointer-events: none;
	}
	.hero .eyebrow {
		color: var(--color-text-muted);
	}
	.hello {
		margin: 0;
		color: var(--color-accent-ink);
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--text-h3);
	}
	.names {
		margin: 0;
		font-size: var(--text-display);
		line-height: 1.05;
	}
	.names .amp {
		display: block;
		font-style: italic;
		font-size: 0.45em;
		color: var(--color-accent);
	}
	.date-line {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		margin: 0;
		color: var(--color-accent-ink);
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--text-h3);
	}
	.date-line::before,
	.date-line::after {
		content: '';
		width: 4rem;
		height: 1px;
		background: var(--color-accent);
	}
	.place {
		margin: 0;
		color: var(--color-text-muted);
		font-size: var(--text-caption);
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}
	.scroll-hint {
		position: absolute;
		bottom: var(--space-4);
		color: var(--color-accent);
		font-size: var(--text-caption);
		letter-spacing: 0.2em;
		text-decoration: none;
		animation: bob 2s ease-in-out infinite;
	}

	/* Плавный выход при загрузке — по очереди, без «цирка» */
	.hero-inner > * {
		opacity: 0;
		animation: hero-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
	}
	.photo {
		animation-delay: 0.05s;
	}
	.hello {
		animation-delay: 0.22s;
	}
	.hero-inner > .eyebrow {
		animation-delay: 0.32s;
	}
	.names {
		animation-delay: 0.44s;
	}
	.date-line {
		animation-delay: 0.58s;
	}
	.place {
		animation-delay: 0.7s;
	}
	.scroll-hint {
		opacity: 0;
		animation:
			hero-in 0.8s ease 1s forwards,
			bob 2s ease-in-out 1.8s infinite;
	}

	@keyframes hero-in {
		from {
			opacity: 0;
			transform: translateY(14px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	@keyframes bob {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(0.35rem);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.hero-inner > *,
		.scroll-hint {
			animation: none;
			opacity: 1;
			transform: none;
		}
	}
</style>
