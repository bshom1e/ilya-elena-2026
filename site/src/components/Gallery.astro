---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Section from './Section.astro';

// Галерея читает папку сама: положил файлы в src/assets/gallery/ — они появились.
// Пока файлов нет — рисуем стилизованные заглушки, код при добавлении фото не меняется.
const modules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/gallery/*.{jpg,jpeg,png,webp}',
	{ eager: true }
);
const photos = Object.entries(modules)
	.sort(([a], [b]) => a.localeCompare(b))
	.map(([, mod]) => mod.default);

const PLACEHOLDERS = 10;
const hasPhotos = photos.length > 0;

// Крупные версии для лайтбокса — грузятся только при открытии.
const full = hasPhotos
	? await Promise.all(photos.map((p) => getImage({ src: p, format: 'webp', width: 1400, quality: 80 })))
	: [];
---

<Section id="gallery" alt eyebrow="Немного нас" title="Галерея" wide>
	<div class="grid">
		{
			hasPhotos
				? photos.map((photo, i) => (
						<button class="tile" type="button" data-lb={i} aria-label={`Открыть фото ${i + 1}`}>
							<Image src={photo} alt={`Фотография ${i + 1}`} widths={[320, 640]} loading="lazy" />
						</button>
					))
				: Array.from({ length: PLACEHOLDERS }).map(() => (
						<figure class="tile -placeholder">
							<span class="mono">И&amp;Е</span>
						</figure>
					))
		}
	</div>
	{!hasPhotos && <p class="note">Фотографии появятся ближе к торжеству</p>}
</Section>

{
	hasPhotos && (
		<div
			class="lightbox"
			id="gallery-lightbox"
			role="dialog"
			aria-modal="true"
			aria-label="Просмотр фотографии"
			aria-hidden="true"
			data-srcs={JSON.stringify(full.map((f) => f.src))}
		>
			<button class="lb-btn -close" type="button" aria-label="Закрыть">&times;</button>
			<button class="lb-btn -prev" type="button" aria-label="Предыдущее фото">&#8249;</button>
			<figure class="lb-stage">
				<img class="lb-img" alt="" />
			</figure>
			<button class="lb-btn -next" type="button" aria-label="Следующее фото">&#8250;</button>
			<p class="lb-count" aria-hidden="true" />
		</div>
	)
}

<style>
	.grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-2);
	}
	.tile {
		margin: 0;
		padding: 0;
		border: none;
		aspect-ratio: 1 / 1;
		border-radius: var(--radius);
		overflow: hidden;
		background: var(--color-surface);
	}
	button.tile {
		cursor: pointer;
		transition: transform var(--transition), box-shadow var(--transition);
	}
	button.tile:hover {
		transform: translateY(-2px);
		box-shadow: 0 14px 30px -20px rgba(61, 56, 51, 0.7);
	}
	button.tile:focus-visible {
		outline: 2px solid var(--color-accent-ink);
		outline-offset: 2px;
	}
	.tile :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
	}
	button.tile:hover :global(img) {
		transform: scale(1.04);
	}
	.tile.-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-line);
		background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-surface) 100%);
	}
	.mono {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--text-h3);
		color: var(--color-accent);
		opacity: 0.55;
	}
	.note {
		margin: var(--space-4) 0 0;
		text-align: center;
		color: var(--color-text-muted);
		font-size: var(--text-caption);
	}
	@media (min-width: 40rem) {
		.grid {
			grid-template-columns: repeat(3, 1fr);
			gap: var(--space-3);
		}
	}

	/* ─── Лайтбокс ─────────────────────────────────────────────── */
	.lightbox {
		position: fixed;
		inset: 0;
		z-index: 50;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: clamp(0.25rem, 2vw, 1.5rem);
		padding: clamp(0.75rem, 3vw, 2rem);
		background: rgba(43, 38, 33, 0.82);
		backdrop-filter: blur(3px);
		opacity: 0;
		visibility: hidden;
		transition: opacity 300ms ease, visibility 300ms ease;
	}
	.lightbox.-open {
		opacity: 1;
		visibility: visible;
	}
	.lb-stage {
		grid-column: 1 / -1;
		grid-row: 1;
		margin: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 0;
		height: 100%;
	}
	.lb-img {
		max-width: min(92vw, 60rem);
		max-height: 82vh;
		border-radius: var(--radius);
		box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.6);
		opacity: 0;
		transform: scale(0.96);
		transition: opacity 320ms ease, transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
	}
	.lightbox.-open .lb-img.-ready {
		opacity: 1;
		transform: scale(1);
	}
	.lb-btn {
		position: relative;
		z-index: 1;
		display: grid;
		place-items: center;
		width: 2.75rem;
		height: 2.75rem;
		border: none;
		border-radius: 50%;
		background: rgba(250, 247, 242, 0.12);
		color: #faf7f2;
		font-size: 1.75rem;
		line-height: 1;
		cursor: pointer;
		transition: background var(--transition), transform var(--transition);
	}
	.lb-btn:hover {
		background: rgba(250, 247, 242, 0.24);
	}
	.lb-btn:active {
		transform: scale(0.94);
	}
	.lb-btn:focus-visible {
		outline: 2px solid #faf7f2;
		outline-offset: 2px;
	}
	.lb-btn.-close {
		position: absolute;
		top: clamp(0.75rem, 3vw, 1.5rem);
		right: clamp(0.75rem, 3vw, 1.5rem);
		font-size: 2rem;
	}
	.lb-btn.-prev {
		grid-column: 1;
		grid-row: 1;
	}
	.lb-btn.-next {
		grid-column: 3;
		grid-row: 1;
	}
	.lb-count {
		grid-column: 1 / -1;
		grid-row: 2;
		margin: 0;
		text-align: center;
		color: rgba(250, 247, 242, 0.7);
		font-size: var(--text-caption);
		letter-spacing: 0.14em;
	}
	@media (prefers-reduced-motion: reduce) {
		.tile :global(img),
		.lb-img,
		.lightbox {
			transition: opacity 200ms ease;
		}
		.lb-img {
			transform: none;
		}
		button.tile:hover {
			transform: none;
		}
	}
</style>

<script>
	const lb = document.getElementById('gallery-lightbox');
	if (lb) {
		const srcs: string[] = JSON.parse(lb.dataset.srcs || '[]');
		const img = lb.querySelector<HTMLImageElement>('.lb-img')!;
		const count = lb.querySelector<HTMLElement>('.lb-count')!;
		const tiles = document.querySelectorAll<HTMLElement>('.tile[data-lb]');
		let index = 0;

		const show = (i: number) => {
			index = (i + srcs.length) % srcs.length;
			img.classList.remove('-ready');
			const next = new window.Image();
			next.onload = () => {
				img.src = next.src;
				img.classList.add('-ready');
			};
			next.src = srcs[index];
			count.textContent = `${index + 1} / ${srcs.length}`;
		};

		const open = (i: number) => {
			show(i);
			lb.classList.add('-open');
			lb.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden';
		};
		const close = () => {
			lb.classList.remove('-open');
			lb.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
		};

		tiles.forEach((tile) =>
			tile.addEventListener('click', () => open(Number(tile.dataset.lb)))
		);
		lb.querySelector('.-prev')!.addEventListener('click', () => show(index - 1));
		lb.querySelector('.-next')!.addEventListener('click', () => show(index + 1));
		lb.querySelector('.-close')!.addEventListener('click', close);
		// Клик по фону (не по фото/кнопкам) — закрыть.
		lb.addEventListener('click', (e) => {
			if (e.target === lb || (e.target as HTMLElement).classList.contains('lb-stage')) close();
		});

		document.addEventListener('keydown', (e) => {
			if (!lb.classList.contains('-open')) return;
			if (e.key === 'Escape') close();
			else if (e.key === 'ArrowLeft') show(index - 1);
			else if (e.key === 'ArrowRight') show(index + 1);
		});

		// Свайп на телефоне.
		let startX = 0;
		lb.addEventListener('touchstart', (e) => (startX = e.touches[0].clientX), { passive: true });
		lb.addEventListener('touchend', (e) => {
			const dx = e.changedTouches[0].clientX - startX;
			if (Math.abs(dx) > 45) show(index + (dx < 0 ? 1 : -1));
		});
	}
</script>
