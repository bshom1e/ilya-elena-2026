---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Section from './Section.astro';

// Галерея читает папку сама: положил файлы в src/assets/gallery/ — они появились.
// Пока файлов нет — рисуем стилизованные заглушки, код при добавлении фото не меняется.
const modules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/gallery/*.{jpg,jpeg,png,webp}',
	{ eager: true }
);
const photos = Object.entries(modules)
	.sort(([a], [b]) => a.localeCompare(b))
	.map(([, mod]) => mod.default);

const PLACEHOLDERS = 10;
const hasPhotos = photos.length > 0;
---

<Section id="gallery" alt eyebrow="Немного нас" title="Галерея" wide>
	<div class="grid">
		{
			hasPhotos
				? photos.map((photo, i) => (
						<figure class="tile">
							<Image src={photo} alt={`Фотография ${i + 1}`} widths={[320, 640]} loading="lazy" />
						</figure>
					))
				: Array.from({ length: PLACEHOLDERS }).map(() => (
						<figure class="tile -placeholder">
							<span class="mono">И&amp;Е</span>
						</figure>
					))
		}
	</div>
	{!hasPhotos && <p class="note">Фотографии появятся ближе к торжеству</p>}
</Section>

<style>
	.grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-2);
	}
	.tile {
		margin: 0;
		aspect-ratio: 1 / 1;
		border-radius: var(--radius);
		overflow: hidden;
		background: var(--color-surface);
	}
	.tile :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.tile.-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-line);
		background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-surface) 100%);
	}
	.mono {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--text-h3);
		color: var(--color-accent);
		opacity: 0.55;
	}
	.note {
		margin: var(--space-4) 0 0;
		text-align: center;
		color: var(--color-text-muted);
		font-size: var(--text-caption);
	}
	@media (min-width: 40rem) {
		.grid {
			grid-template-columns: repeat(3, 1fr);
			gap: var(--space-3);
		}
	}
</style>
