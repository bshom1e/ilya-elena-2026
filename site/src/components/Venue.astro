---
import Section from './Section.astro';
import { wedding } from '../data/wedding';
const { venue } = wedding;
---

<Section id="venue" alt eyebrow="Где встречаемся" title="Место" wide>
	<div class="venue">
		<p class="name">{venue.name}</p>
		<p class="city">{venue.city}</p>
		<div class="map">
			<iframe
				src={venue.mapEmbed}
				title={`Карта: ${venue.name}`}
				loading="lazy"
				referrerpolicy="no-referrer-when-downgrade"
				allowfullscreen></iframe>
		</div>
		<a class="btn btn-ghost" href={venue.mapLink} target="_blank" rel="noopener noreferrer">
			Открыть в Яндекс.Картах
		</a>
	</div>
</Section>

<style>
	.venue {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-3);
		text-align: center;
	}
	.name {
		margin: 0;
		font-family: var(--font-display);
		font-size: var(--text-h3);
		color: var(--color-text);
	}
	.city {
		margin: 0;
		color: var(--color-text-muted);
		font-size: var(--text-caption);
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}
	.map {
		width: 100%;
		margin: var(--space-2) 0;
		aspect-ratio: 16 / 10;
		border: 1px solid var(--color-line);
		border-radius: var(--radius);
		overflow: hidden;
		background: var(--color-surface);
	}
	.map iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}
	@media (max-width: 40rem) {
		.map {
			aspect-ratio: 3 / 4;
		}
	}
</style>
