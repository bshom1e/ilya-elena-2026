---
import Section from './Section.astro';
import { wedding, type Personalization } from '../data/wedding';

interface Props {
	/** На именной странице — персональные обращение и тексты */
	personal?: Personalization;
}
const { personal } = Astro.props;
const { invitation } = wedding;
const lead = personal?.lead ?? invitation.lead;
const body = personal?.body ?? invitation.body;
---

<Section id="invitation" eyebrow={personal ? 'Приглашение' : 'Дорогие гости'}>
	<div class="invite">
		<span class="ornament">&#10086;</span>
		{personal && <p class="greeting">{personal.greeting}</p>}
		<p class="lead">{lead}</p>
		<p class="body">{body}</p>
	</div>
</Section>

<style>
	.invite {
		text-align: center;
	}
	.ornament {
		display: block;
		margin-bottom: var(--space-4);
		color: var(--color-accent);
		font-size: var(--text-h2);
		line-height: 1;
	}
	.greeting {
		margin: 0 0 var(--space-3);
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--text-h2);
		color: var(--color-accent-ink);
	}
	.lead {
		margin: 0 0 var(--space-3);
		font-size: var(--text-lg);
	}
	.body {
		margin: 0;
		color: var(--color-text-muted);
	}
</style>
